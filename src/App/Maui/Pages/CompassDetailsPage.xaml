<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:WhereToFly.App.Controls"
             xmlns:viewmodels="clr-namespace:WhereToFly.App.ViewModels"
             x:Class="WhereToFly.App.Pages.CompassDetailsPage"
             x:DataType="viewmodels:CompassDetailsViewModel"
             Title="Compass">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Set target direction"
                     IconImageSource="compass_rose.png"
                     Command="{Binding SetTargetDirectionCommand}"
                     Order="Primary" Priority="0" />

        <ToolbarItem Text="Clear compass target"
                     IconImageSource="close.png"
                     Command="{Binding ClearCompassTargetCommand}"
                     Order="Primary" Priority="1" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <ScrollView Orientation="Vertical">

            <!-- Flex layout with all compass details -->
            <FlexLayout Direction="Row"
                        AlignItems="Start"
                        AlignContent="Start"
                        JustifyContent="Start"
                        Wrap="Wrap">

                <!-- Compass -->
                <Grid Style="{StaticResource PositionInfoTileStyle}"
                      VerticalOptions="Fill"
                      HorizontalOptions="Fill">

                    <Grid.WidthRequest>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="Android" Value="380" />
                            <On Platform="WinUI" Value="600" />
                        </OnPlatform>
                    </Grid.WidthRequest>
                    <Grid.HeightRequest>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="Android" Value="380" />
                            <On Platform="WinUI" Value="600" />
                        </OnPlatform>
                    </Grid.HeightRequest>

                    <Border Style="{StaticResource PositionInfoBorderStyle}">

                        <controls:CompassView VerticalOptions="Fill"
                                              HorizontalOptions="Fill"
                                              Heading="{Binding TrueNorthHeadingInDegrees}"
                                              TargetDirection="{Binding TargetDirectionInDegrees}"
                                              SunriseDirection="{Binding SunriseDirectionInDegrees}"
                                              SunsetDirection="{Binding SunsetDirectionInDegrees}"
                                              Style="{StaticResource CompassStyle}" />
                    </Border>
                </Grid>

                <!-- Magnetic-north Heading -->
                <Grid Style="{StaticResource PositionInfoTileStyle}"
                      IsVisible="{Binding IsMagneticNorthHeadingAvail}">
                    <Border Style="{StaticResource PositionInfoBorderStyle}">
                        <VerticalStackLayout>
                            <Label Text="Magnetic Heading [°]" />
                            <Label Text="{Binding MagneticNorthHeadingInDegrees}" FontSize="32" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- True-north Heading -->
                <Grid Style="{StaticResource PositionInfoTileStyle}"
                      IsVisible="{Binding IsTrueNorthHeadingAvail}">
                    <Border Style="{StaticResource PositionInfoBorderStyle}">
                        <VerticalStackLayout>
                            <Label Text="True North Heading [°]" />
                            <Label Text="{Binding TrueNorthHeadingInDegrees}" FontSize="32" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Target direction -->
                <Grid Style="{StaticResource PositionInfoTileStyle}"
                      IsVisible="{Binding IsTargetDirectionAvail}">
                    <Border Style="{StaticResource PositionInfoBorderStyle}">
                        <VerticalStackLayout>
                            <Label Text="Direction [°]" />
                            <Label Text="{Binding TargetDirectionText}" FontSize="32" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Distance -->
                <Grid Style="{StaticResource PositionInfoTileStyle}">
                    <Border Style="{StaticResource PositionInfoBorderStyle}">
                        <VerticalStackLayout>
                            <Label Text="Distance" />
                            <Label Text="{Binding Distance}" FontSize="32" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Height difference -->
                <Grid Style="{StaticResource PositionInfoTileStyle}">
                    <Border Style="{StaticResource PositionInfoBorderStyle}">
                        <VerticalStackLayout>
                            <Label Text="Height difference" />
                            <Label Text="{Binding HeightDifference}"
                                   FontSize="32"
                                   FontAutoScalingEnabled="True" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </FlexLayout>
        </ScrollView>

    </ContentPage.Content>
</ContentPage>
